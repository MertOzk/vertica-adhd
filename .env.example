# Copy to .env and fill in the real values before `docker compose up`.

# LLM routing (the Vertica router exposes OpenAI-compatible /v1/chat/completions)
VERTICA_ROUTER_URL=http://vertica-router:8080
VERTICA_ROUTER_API_KEY=changeme
DEFAULT_MODEL=claude-sonnet-4-6

# Home Assistant for push notifications
HA_URL=http://homeassistant:8123
HA_TOKEN=paste_a_long_lived_access_token_here
HA_NOTIFY_TARGET=mobile_app_merts_iphone

# Where the mobile PWA is reachable (Tailscale magic DNS)
PUBLIC_URL=https://vertica.tailnet.ts.net

# User defaults (seeded on first boot)
USER_NAME=Mert
USER_TIMEZONE=America/Los_Angeles
MORNING_CRON=0 9 * * *
EVENING_CRON=0 21 * * *

# Data directory inside the container (matches the volume mount)
DATA_DIR=/data

# Dev-only: used by the compose profile with the router stub
ANTHROPIC_API_KEY=
